# Copy to .env and adjust for your environment

# ── Infrastructure ────────────────────────────────────────────────────────────
AMQP_URI=amqp://guest:guest@localhost:5672
MONGO_URI=mongodb://localhost:27017
REDIS_URI=redis://localhost:6379
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# ── Dispatcher — HTTP webhook (leave blank to disable) ────────────────────────
WEBHOOK_URL=http://localhost:9000/alarm

# ── Dispatcher — Email via SMTP (all three required, or email is disabled) ───
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=changeme
ALARM_EMAIL_FROM=alerts@example.com
ALARM_EMAIL_TO=admin@example.com

# ── Mock publisher ────────────────────────────────────────────────────────────
# How often mock-device / mock-alarm publish events (milliseconds)
PUBLISH_INTERVAL_MS=2000
